{
  "name": "bcn",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "ios-16": "react-native run-ios --simulator 'iPhone 16 Pro'",
    "lint": "eslint .",
    "start": "npx react-native start --reset-cache",
    "test": "jest",
    "clean": "cd android && ./gradlew clean",
    "release": "cd android && ./gradlew aR",
    "bundle": "cd android && ./gradlew bR",
    "x": "cd ios && xed .",
    "pod": "cd ios && pod install",
    "releaseInstall": "cd android && ./gradlew aR && adb install app/build/outputs/apk/release/app-release.apk",
    "removePod": "rm -rf ~/Library/Developer/Xcode/DerivedData/ && rm -rf build && rm -rf Podfile.lock && rm -rf Pods",
    "postinstall": "patch-package"
  },
