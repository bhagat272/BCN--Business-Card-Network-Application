            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.DEFAULT" />
            <category android:name="android.intent.category.BROWSABLE" />

            <data
                android:scheme="https"
                android:host="business-cn.com"
                android:pathPrefix="/share-bcn" />
                <data android:scheme="https" android:host="www.business-cn.com" android:pathPrefix="/share-bcn" />
        </intent-filter> -->


        <intent-filter>
          <action android:name="android.intent.action.VIEW" />
          <category android:name="android.intent.category.DEFAULT" />
          <category android:name="android.intent.category.BROWSABLE" />
          <data
              android:scheme="myapp"
              android:host="localhost" />
        </intent-filter>

        <!-- Deep link for custom scheme (internal testing) -->
        <intent-filter android:label="@string/app_name">
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.DEFAULT" />
            <category android:name="android.intent.category.BROWSABLE" />

            <data android:scheme="bcn" android:host="com.bcnapp" />
            <data android:scheme="bcn" android:host="bcn" />
        </intent-filter>

        <!-- Production domain 1 -->
        <intent-filter android:autoVerify="true">
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.DEFAULT" />
            <category android:name="android.intent.category.BROWSABLE" />

            <data
                android:scheme="https"
                android:host="business-cn.com"
                android:pathPrefix="/share-bcn" />
        </intent-filter>

        <!-- Production domain 2 -->
        <intent-filter android:autoVerify="true">
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.DEFAULT" />
            <category android:name="android.intent.category.BROWSABLE" />

            <data
                android:scheme="https"
                android:host="www.business-cn.com"
                android:pathPrefix="/share-bcn" />
        </intent-filter>

        
      </activity>
    </application>

    <queries>
      <intent>
        <action android:name="android.intent.action.VIEW" />
        <data android:scheme="http"/>
      </intent>
      <intent>
        <action android:name="android.intent.action.VIEW" />
        <data android:scheme="https"/>
      </intent>
      <intent>
        <action android:name="android.intent.action.VIEW" />
        <data android:scheme="geo" />
      </intent>
      <intent>
        <action android:name="android.intent.action.VIEW" />
        <data android:scheme="google.navigation" />
      </intent>
        <intent>
        <action android:name="android.intent.action.VIEW" />
        <data android:scheme="tel" />
      </intent>
      <intent>
        <action android:name="android.intent.action.VIEW" />
        <data android:scheme="mailto" />
      </intent>
    </queries>
</manifest>
